# MLflow remote tracking server
MLFLOW_TRACKING_URI=http://16.176.132.85:5000
MLFLOW_EXPERIMENT=customer

# Flask / Gunicorn
PORT=5001
LOG_LEVEL=INFO

# Model file paths (relative to project root)
# These are created by:  python scripts/export_models.py
KMEANS_MODEL_PATH=models/kmeans_model.pkl
RF_MODEL_PATH=models/rf_model.pkl
SCALER_MODEL_PATH=models/scaler.pkl
