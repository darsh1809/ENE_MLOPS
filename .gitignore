# Virtual envs
.venv/
venv/
env/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# MLflow local storage (tracked on remote server)
mlartifacts/
mlruns/
mlflow.db

# Data — large files should NOT be committed
data/
!data/.gitkeep

# Exported models (generated by scripts/export_models.py)
models/*.pkl
models/*.joblib
!models/.gitkeep

# Misc
*.log
.DS_Store
Thumbs.db
